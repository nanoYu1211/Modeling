library(caret)
library(randomForest)
library(dplyr)
library(glmnet)  

data <- read.csv("code.Public database data.csv")


data <- data %>%
  mutate(
    group_id = paste(material, shape, cell_line, Via_test, Exposure_time, sep = "_")
  )

X <- data %>% select(-viability, -group_id)  
Y <- data$viability  

sum(is.na(Y))  
sum(is.na(X)) 
str(X)         

preprocess_params <- preProcess(X, method = c("center", "scale"))
X <- predict(preprocess_params, X)

set.seed(258)

unique_groups <- unique(data$group_id)
train_groups <- sample(unique_groups, size = floor(0.8 * length(unique_groups)))

train_index <- which(data$group_id %in% train_groups)
test_index <- which(!(data$group_id %in% train_groups))

X_train <- X[train_index, ]
Y_train <- Y[train_index]
X_test <- X[test_index, ]
Y_test <- Y[test_index]

ctrl <- trainControl(
  method = "cv", 
  number = 5,   
  savePredictions = TRUE, 
  summaryFunction = defaultSummary  
)

tune_grid <- expand.grid(mtry = c(2, 4, 6, 8, 10)) 

set.seed(258)
rf_model <- train(
  x = X_train,  
  y = Y_train,  
  method = "rf",  
  trControl = ctrl,  
  tuneGrid = tune_grid, 
  metric = "RMSE",  
  ntree = 800,  
  nodesize = 15,  
  maxnodes = 20, 
)

print(rf_model)

cv_metrics <- rf_model$resample
cat("\n五折交叉验证评估指标：\n")
print(cv_metrics)

avg_cv_metrics <- colMeans(cv_metrics[, c("RMSE", "Rsquared", "MAE")])
cat("\n五折交叉验证平均评估指标：\n")
print(avg_cv_metrics)

train_predictions <- predict(rf_model, X_train)
test_predictions <- predict(rf_model, X_test)

calculate_metrics <- function(actual, predicted) {
  r2_score <- 1 - (sum((actual - predicted)^2) / sum((actual - mean(actual))^2))
  rmse_score <- sqrt(mean((actual - predicted)^2))
  mae_score <- mean(abs(actual - predicted))
  return(list(R2 = r2_score, RMSE = rmse_score, MAE = mae_score))
}

train_metrics <- calculate_metrics(Y_train, train_predictions)
test_metrics <- calculate_metrics(Y_test, test_predictions)

cat("\n训练集评估指标：\n")
cat("Train R2-score:", train_metrics$R2, "\n")
cat("Train RMSE:", train_metrics$RMSE, "\n")
cat("Train MAE:", train_metrics$MAE, "\n")
cat("\n测试集评估指标：\n")
cat("Test R2-score:", test_metrics$R2, "\n")
cat("Test RMSE:", test_metrics$RMSE, "\n")
cat("Test MAE:", test_metrics$MAE, "\n")


library(SHAPforxgboost)
library(ggbeeswarm)
library(randomForest)
library(ggplot2)
library(dplyr)

final_rf_model <- rf_model$finalModel

rf_importance <- importance(final_rf_model)
rf_importance_df <- data.frame(
  Feature = rownames(rf_importance),
  Importance = rf_importance[, "IncNodePurity"]  
) %>%
  arrange(desc(Importance))

cat("\n=== Random Forest Feature Importance (MeanDecreaseGini) ===\n")
print(head(rf_importance_df, 20))

if (!require("fastshap")) install.packages("fastshap")
library(fastshap)

X_all <- rbind(X_train, X_test)
X_matrix <- as.matrix(X_all)

pred_fun <- function(object, newdata) {
  predict(object, newdata)
}

set.seed(258)
bg_indices <- sample(1:nrow(X_train), size = min(100, nrow(X_train)))
shap_values <- fastshap::explain(
  final_rf_model,
  X = X_matrix,
  pred_wrapper = pred_fun,
  nsim = 50, 
  adjust = TRUE,
  background_data = X_train[bg_indices, ]
)

shap_long <- data.frame(
  Feature = rep(colnames(X_matrix), each = nrow(X_matrix)),
  SHAP = as.vector(shap_values),
  Value = as.vector(X_matrix),
  DataType = rep(c("Train", "Test"), 
                 times = c(nrow(X_train), nrow(X_test)))
)

shap_importance <- shap_long %>%
  group_by(Feature) %>%
  summarise(Importance = mean(abs(SHAP))) %>%
  arrange(desc(Importance))

top_features <- shap_importance$Feature

cat("\n=== SHAP Feature Importance Ranking (based on mean |SHAP|) ===\n")
print(head(shap_importance, 20))
shap_long_filtered <- shap_long %>%
  filter(abs(SHAP) <= quantile(abs(SHAP), 0.99))  
cat("\nSHAP value filtering results:\n")
cat("Original data points:", nrow(shap_long), "\n")
cat("Filtered data points:", nrow(shap_long_filtered), "\n")
cat("SHAP value range after filtering:", 
    round(min(shap_long_filtered$SHAP), 2), "to", 
    round(max(shap_long_filtered$SHAP), 2), "\n")


color_high <- "#D62728"  
color_low <- "blue"      

shap_beeswarm_data <- shap_long_filtered %>%
  filter(Feature %in% top_features[1:min(15, length(top_features))]) %>% 
  mutate(Feature = factor(Feature, levels = rev(top_features[1:min(15, length(top_features))])))

shap_beeswarm_data <- shap_beeswarm_data %>%
  group_by(Feature) %>%
  mutate(Value_scaled = scales::rescale(Value, to = c(0, 1))) %>%
  ungroup()

shap_beeswarm_plot <- ggplot(shap_beeswarm_data, aes(x = SHAP, y = Feature, color = Value_scaled)) +
  geom_vline(xintercept = 0, color = "black", linetype = "solid", linewidth = 0.8, alpha = 0.8) +
  geom_quasirandom(
    size = 1.6,
    alpha = 0.8,
    groupOnX = FALSE,
    varwidth = TRUE,
    width = 0.3
  ) +
  scale_color_gradientn(
    name = "Feature Value",
    colors = c(color_low, color_high),
    values = c(0, 1),
    breaks = c(0, 1),
    labels = c("Low", "High")
  ) +
  scale_x_continuous(
    breaks = pretty(shap_beeswarm_data$SHAP, n = 6),
    limits = c(-max(abs(shap_beeswarm_data$SHAP)) * 1.1, 
               max(abs(shap_beeswarm_data$SHAP)) * 1.1)
  ) +
  labs(
    title = "Random Forest - SHAP Feature Importance Beeswarm Plot",
    subtitle = "Color indicates feature value: Red=High, Blue=Low",
    x = "SHAP Value (Impact on Prediction)",
    y = "Feature",
    caption = paste("Positive SHAP: Increases prediction | Negative SHAP: Decreases prediction\n",
                    "Features ordered by mean |SHAP| | Random Forest model")
  ) +
  theme_classic(base_size = 12) +
  theme(
    plot.title = element_text(face = "bold", size = 16, hjust = 0.5),
    plot.subtitle = element_text(size = 12, hjust = 0.5, color = "grey40"),
    plot.caption = element_text(size = 10, color = "grey50", hjust = 0),
    axis.title = element_text(face = "bold", size = 12),
    axis.text.y = element_text(size = 10, color = "black"),
    axis.text.x = element_text(size = 10, color = "black"),
    axis.line = element_line(color = "black", linewidth = 0.8),
    axis.ticks = element_line(color = "black", linewidth = 0.5),
    axis.ticks.length = unit(0.2, "cm"),
    legend.position = "right",
    legend.title = element_text(face = "bold", size = 10),
    legend.text = element_text(size = 9),
    plot.background = element_rect(fill = "white", color = NA),
    panel.background = element_rect(fill = "white", color = NA),
    legend.background = element_rect(fill = "white", color = NA)
  )

print(shap_beeswarm_plot)

ggsave("RF_SHAP_beeswarm_plot.tiff", shap_beeswarm_plot, 
       width = 12, height = 10, dpi = 300, bg = "white")

mean_shap <- colMeans(abs(shap_values))
mean_shap_df <- data.frame(
  Feature = names(mean_shap),
  MeanSHAP = mean_shap
) %>%
  mutate(Feature = factor(Feature, levels = rev(top_features))) %>%
  arrange(desc(MeanSHAP)) %>%
  head(17)  

shap_summary_plot <- ggplot(mean_shap_df, aes(x = MeanSHAP, y = Feature)) +
  geom_col(fill = "steelblue", alpha = 0.85, width = 0.7) +
  geom_text(aes(label = sprintf("%.4f", MeanSHAP)), hjust = -0.1, size = 3.2) +
  labs(
    title = "Random Forest - SHAP Feature Importance Summary",
    subtitle = "Feature importance ranking based on mean absolute SHAP value",
    x = "Mean |SHAP| (Feature Importance)",
    y = "Feature",
    caption = paste("Based on Random Forest model | Total features:", ncol(X_matrix))
  ) +
  theme_minimal(base_size = 12) +
  theme(
    plot.title = element_text(face = "bold", size = 14, hjust = 0.5),
    plot.subtitle = element_text(size = 11, hjust = 0.5, color = "grey40"),
    plot.caption = element_text(size = 9, color = "grey50", hjust = 0),
    axis.title = element_text(face = "bold", size = 12),
    axis.text.y = element_text(size = 10, color = "black"),
    axis.text.x = element_text(size = 10, color = "black"),
    panel.grid.major.y = element_blank(),
    panel.grid.minor = element_blank(),
    panel.grid.major.x = element_line(color = "grey90", linewidth = 0.3)
  ) +
  scale_x_continuous(expand = expansion(mult = c(0, 0.1)))

print(shap_summary_plot)

ggsave("RF_SHAP_summary_plot.tiff", shap_summary_plot, 
       width = 10, height = max(7, nrow(mean_shap_df) * 0.3), dpi = 300)
